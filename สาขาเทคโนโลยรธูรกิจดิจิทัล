<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DBT | เทคโนโลยีธุรกิจดิจิทัล</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:"Prompt",sans-serif;
}

body{
    background:#f5f5f5;
}

header{
    background:#5B2C91;
    color:white;
    padding:15px 60px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    font-size:28px;
    font-weight:bold;
}

nav a{
    color:white;
    text-decoration:none;
    margin-left:25px;
    font-size:17px;
}

.hero{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:70px;
    background:white;
}

.hero-text{
    width:50%;
}

.hero-text h1{
    font-size:50px;
    color:#5B2C91;
}

.hero-text p{
    margin:20px 0;
    color:#666;
    font-size:20px;
}

button{
    background:#5B2C91;
    color:white;
    border:none;
    padding:15px 35px;
    border-radius:40px;
    cursor:pointer;
}

.hero img{
    width:450px;
}

.section{
    padding:60px;
}

.section h2{
    text-align:center;
    color:#5B2C91;
    margin-bottom:40px;
}

.card-box{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:30px;
}

.card{
    background:white;
    border-radius:20px;
    box-shadow:0 0 15px rgba(0,0,0,.1);
    overflow:hidden;
    transition:.3s;
}

.card:hover{
    transform:translateY(-10px);
}

.card img{
    width:100%;
}

.card h3{
    padding:15px;
    color:#5B2C91;
}

.card p{
    padding:0 15px 20px;
    color:#666;
}

footer{
    background:#5B2C91;
    color:white;
    text-align:center;
    padding:25px;
    margin-top:60px;
}
</style>

</head>
